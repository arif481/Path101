rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ── User profile (owner read/write, admin full) ─────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Auth profile (created on first sign-in, admin manages)
    match /authProfiles/{uid} {
      // User can create their own profile on first sign-in
      // User can read their own profile
      // Only admin can update (e.g. role, permissions, isAdmin)
      allow create: if isOwner(uid);
      allow read:   if isOwner(uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Plans (user-owned) ──────────────────────────────────
    match /plans/{planId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Sessions (user-owned) ───────────────────────────────
    match /sessions/{sessionId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Bandit logs (user creates + reads own, admin reads all)
    match /banditLogs/{logId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ── Safety flags (user creates, admin manages) ──────────
    match /safetyFlags/{flagId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
    }

    // ── Safety escalation events (user creates, admin reads) ─
    match /safetyEscalationEvents/{eventId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
    }

    // ── Notifications (user reads own, admin reads all) ─────
    match /notificationLogs/{logId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // ── Dead-letter queue (admin only) ──────────────────────
    match /deadLetterJobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /deadLetterReplayAudits/{auditId} {
      allow read, write: if isAdmin();
    }

    // ── Worker metrics (system creates, admin reads) ────────
    match /workerMetrics/{metricId} {
      allow create: if isSignedIn();
      allow read:   if isAdmin();
    }

    // ── Task queue (user enqueues, admin manages) ───────────
    match /taskQueue/{taskId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Scheduler locks (system creates, no user access) ────
    // Used by GitHub Actions scheduler for distributed dedup
    match /schedulerLocks/{lockId} {
      // Only admin SDK (server) can write; no client access
      allow read, write: if false;
    }

    // ── Deny all other collections by default ───────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
