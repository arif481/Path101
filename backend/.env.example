# Default local sqlite database
DATABASE_URL=sqlite:///./path101.db
APP_ENV=development
AUTO_MIGRATE=false

# JWT and admin auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_MINUTES=10080
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Redis queue
REDIS_URL=redis://localhost:6379/0
SCHEDULER_INTERVAL_SECONDS=60
NUDGE_LOOKAHEAD_MINUTES=30
NUDGE_LOOKBACK_HOURS=24
NUDGE_LOCK_TTL_SECONDS=86400
BANDIT_EPSILON=0.2
BANDIT_MIN_HISTORY=3
AUTH_RATE_LIMIT_COUNT=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_COUNT=120
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
WORKER_MAX_RETRIES=3
NOTIFICATION_CHANNELS=in_app,email

# Safety triage (rule-based in current MVP)
# Severity is computed from intake text and persisted on safety flags.

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Comma-separated trusted hosts for API requests
TRUSTED_HOSTS=127.0.0.1,localhost

# Example PostgreSQL URL
# DATABASE_URL=postgresql+psycopg://path101_user:password@localhost:5432/path101

# Apply migrations before starting API:
# alembic upgrade head
